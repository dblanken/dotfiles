# Brewfile for dotfiles dependencies
# Install with: brew bundle

# Core development tools
brew "git"
brew "stow"
brew "tmux"
brew "neovim"
brew "zsh"

# Terminal emulator
cask "alacritty"

# Fonts
cask "font-cascadia-code-nf"

# Version managers
brew "mise"  # Modern runtime version manager (replaces asdf)

# Shell utilities
brew "fzf"          # Fuzzy finder
brew "ripgrep"      # Fast grep alternative
brew "fd"           # Fast find alternative
brew "bat"          # Better cat
brew "eza"          # Better ls
brew "jq"           # JSON processor

# YaleSites-specific dependencies
brew "mysql-client@8.4"  # Pantheon requires 8.4 syntax

# Build dependencies (for PHP/Ruby/etc)
brew "openssl@1.1"
brew "libxml2"
brew "imagemagick@6"
brew "gmp"
brew "libpng"
brew "libtiff"
brew "ncurses"
brew "mpfr"
brew "libyaml"
brew "icu4c"
brew "readline"
brew "webp"
brew "unixodbc"
brew "jpeg"
brew "libpq"
brew "imagemagick"

