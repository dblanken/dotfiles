#!/usr/bin/env bash
# ask-ollama: Ask a quick question to a local Ollama model.
# Usage: ask-ollama "your question here"
#        ask-ollama -m qwen3:4b "your question here"
#
# Environment:
#   OLLAMA_MODEL              Override default model (default: qwen2.5-coder:7b)
#   HSA_OVERRIDE_GFX_VERSION  AMD GPU GFX version for ROCm (Linux only, default: 10.3.0)

set -euo pipefail

MODEL="${OLLAMA_MODEL:-qwen2.5-coder:7b}"
PROMPT=""
STARTED_PID=""

usage() {
  echo "Usage: $(basename "$0") [-m model] \"your question\""
  echo "  -m  Model to use (default: $MODEL)"
  echo ""
  echo "Environment:"
  echo "  OLLAMA_MODEL              Override default model"
  echo "  HSA_OVERRIDE_GFX_VERSION  AMD GPU GFX version (Linux only, default: 10.3.0)"
  exit 1
}

while getopts ":m:h" opt; do
  case $opt in
    m) MODEL="$OPTARG" ;;
    h) usage ;;
    \?) echo "Unknown option: -$OPTARG" >&2; usage ;;
  esac
done
shift $((OPTIND - 1))

[[ $# -eq 0 ]] && usage
PROMPT="$*"

ollama_is_running() {
  curl -sf http://localhost:11434/api/tags > /dev/null 2>&1
}

# Set AMD GPU override on Linux for ROCm/HSA compatibility (must be set before starting server)
if [[ "$(uname -s)" == "Linux" ]]; then
  export HSA_OVERRIDE_GFX_VERSION="${HSA_OVERRIDE_GFX_VERSION:-10.3.0}"
fi

if ! ollama_is_running; then
  echo "Starting Ollama..." >&2
  ollama serve > /dev/null 2>&1 &
  STARTED_PID=$!
  for i in {1..10}; do
    ollama_is_running && break
    sleep 1
  done
fi

cleanup() {
  if [[ -n "$STARTED_PID" ]]; then
    echo "" >&2
    echo "Stopping Ollama..." >&2
    kill "$STARTED_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT

ollama run "$MODEL" "$PROMPT"
