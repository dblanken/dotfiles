#!/usr/bin/env bash
# claude-local: Run Claude Code against a local Ollama instance.
# Usage: claude-local [claude args...]

set -euo pipefail

STARTED_PID=""

# Set AMD GPU override on Linux for ROCm/HSA compatibility (must be set before starting server)
if [[ "$(uname -s)" == "Linux" ]]; then
  export HSA_OVERRIDE_GFX_VERSION="${HSA_OVERRIDE_GFX_VERSION:-10.3.0}"
fi

ollama_is_running() {
  curl -sf http://localhost:11434/api/tags > /dev/null 2>&1
}

if ! ollama_is_running; then
  echo "Starting Ollama..." >&2
  ollama serve > /dev/null 2>&1 &
  STARTED_PID=$!
  for i in {1..10}; do
    ollama_is_running && break
    sleep 1
  done
fi

cleanup() {
  if [[ -n "$STARTED_PID" ]]; then
    echo "" >&2
    echo "Stopping Ollama..." >&2
    kill "$STARTED_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT

MODEL="${CLAUDE_LOCAL_MODEL:-qwen2.5-coder:7b}"

# Prepend --model default only if not already specified
if [[ ! " $* " =~ " --model " ]] && [[ ! " $* " =~ " -m " ]]; then
  set -- --model "$MODEL" "$@"
fi

# Pull model if not already available locally
if ! ollama show "$MODEL" > /dev/null 2>&1; then
  echo "Pulling model $MODEL..." >&2
  ollama pull "$MODEL"
fi

ANTHROPIC_BASE_URL="http://localhost:11434" \
ANTHROPIC_AUTH_TOKEN="ollama" \
ANTHROPIC_API_KEY="" \
  claude "$@"
