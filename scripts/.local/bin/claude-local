#!/usr/bin/env bash
# claude-local: Run Claude Code against a local Ollama instance.
# Usage: claude-local [claude args...]

set -euo pipefail

# Set AMD GPU override on Linux for ROCm/HSA compatibility (must be set before starting server)
if [[ "$(uname -s)" == "Linux" ]]; then
  export HSA_OVERRIDE_GFX_VERSION="${HSA_OVERRIDE_GFX_VERSION:-10.3.0}"
fi

exec ollama launch claude ${CLAUDE_LOCAL_MODEL:+--model "$CLAUDE_LOCAL_MODEL" --yes} -- "$@"
