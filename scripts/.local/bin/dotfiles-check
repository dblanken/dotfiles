#!/usr/bin/env bash
#
# dotfiles-check: Validate dotfiles installation and health
#
# This script checks the integrity of your dotfiles installation:
# - Verifies symlinks point to valid targets
# - Checks git submodules are initialized
# - Validates required binaries are executable
# - Tests platform detection
# - Runs shellcheck if available

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Counters
ERRORS=0
WARNINGS=0
CHECKS=0

# Detect dotfiles directory
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"

# Helper functions
print_header() {
    echo -e "\n${BLUE}==>${NC} $1"
}

print_success() {
    echo -e "  ${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "  ${RED}✗${NC} $1"
    (( ++ERRORS ))
}

print_warning() {
    echo -e "  ${YELLOW}⚠${NC} $1"
    (( ++WARNINGS ))
}

print_info() {
    echo -e "  ${BLUE}ℹ${NC} $1"
}

# Check if dotfiles directory exists
check_dotfiles_dir() {
    print_header "Checking dotfiles directory"
    (( ++CHECKS ))

    if [[ ! -d "$DOTFILES_DIR" ]]; then
        print_error "Dotfiles directory not found: $DOTFILES_DIR"
        print_info "Set DOTFILES_DIR environment variable if installed elsewhere"
        return 1
    fi

    print_success "Found dotfiles directory: $DOTFILES_DIR"

    if [[ ! -d "$DOTFILES_DIR/.git" ]]; then
        print_warning "Not a git repository: $DOTFILES_DIR"
    else
        print_success "Git repository detected"
    fi
}

# Check platform detection
check_platform_detection() {
    print_header "Checking platform detection"
    (( ++CHECKS ))

    # Source the OS detection from .zprofile
    if [[ -f "$HOME/.zprofile" ]]; then
        # Extract OS_TYPE detection without running entire .zprofile
        local detected_os
        detected_os=$(uname -s | tr '[:upper:]' '[:lower:]')

        case "$detected_os" in
            darwin)
                print_success "Platform detected: macOS (darwin)"
                ;;
            linux)
                print_success "Platform detected: Linux"

                # Check distribution if on Linux
                if [[ -f /etc/os-release ]]; then
                    # shellcheck source=/dev/null
                    source /etc/os-release
                    print_info "Distribution: ${NAME:-Unknown} ${VERSION_ID:-}"
                fi
                ;;
            *)
                print_warning "Unknown platform: $detected_os"
                ;;
        esac
    else
        print_error ".zprofile not found at $HOME/.zprofile"
    fi
}

# Check symlinks
check_symlinks() {
    print_header "Checking symlinks"
    (( ++CHECKS ))

    local broken_links=0
    local valid_links=0

    # Common dotfiles locations to check
    local locations=(
        "$HOME/.zshrc"
        "$HOME/.zprofile"
        "$HOME/.tmux.conf"
        "$HOME/.gitconfig"
        "$HOME/.config/alacritty"
        "$HOME/.config/lazyvim"
        "$HOME/.config/zsh"
    )

    # Dynamically discover scripts from the stow source
    if [[ -d "$DOTFILES_DIR/scripts/.local/bin" ]]; then
        for script_src in "$DOTFILES_DIR/scripts/.local/bin"/*; do
            locations+=("$HOME/.local/bin/$(basename "$script_src")")
        done
    fi

    for location in "${locations[@]}"; do
        if [[ -L "$location" ]]; then
            # It's a symlink - check if target exists
            if [[ -e "$location" ]]; then
                (( ++valid_links ))
            else
                print_error "Broken symlink: $location -> $(readlink "$location")"
                (( ++broken_links ))
            fi
        elif [[ -e "$location" ]]; then
            print_warning "Not a symlink: $location (may conflict with stow)"
        fi
    done

    if [[ $valid_links -gt 0 ]]; then
        print_success "Found $valid_links valid symlinks"
    fi

    if [[ $broken_links -eq 0 ]]; then
        print_success "No broken symlinks detected"
    else
        print_info "Run 'make clean' to remove broken symlinks"
    fi
}

# Check git submodules
check_submodules() {
    print_header "Checking git submodules"
    (( ++CHECKS ))

    if [[ ! -d "$DOTFILES_DIR/.git" ]]; then
        print_warning "Not a git repository, skipping submodule check"
        return 0
    fi

    cd "$DOTFILES_DIR" || return 1

    # Check if .gitmodules exists
    if [[ ! -f .gitmodules ]]; then
        print_info "No git submodules defined"
        return 0
    fi

    # Get submodule status
    local submodule_output
    submodule_output=$(git submodule status 2>&1)

    # Check for uninitialized submodules (lines starting with -)
    if echo "$submodule_output" | grep -q '^-'; then
        print_error "Uninitialized submodules detected"
        print_info "Run 'git submodule update --init --recursive' to initialize"
        echo "$submodule_output" | grep '^-' | while read -r line; do
            print_info "  Uninitialized: $(echo "$line" | awk '{print $2}')"
        done
    else
        print_success "All submodules initialized"
    fi

    # Check for submodules with available updates (lines starting with +)
    if echo "$submodule_output" | grep -q '^+'; then
        print_warning "Submodules have available updates"
        print_info "Run 'make update' or 'git submodule update --remote' to update"
    fi

    cd - > /dev/null || return 1
}

# Check required binaries
check_binaries() {
    print_header "Checking required binaries"
    (( ++CHECKS ))

    local required_bins=(
        "stow"
        "git"
        "zsh"
    )

    local optional_bins=(
        "tmux"
        "nvim"
        "fzf"
        "rg"
        "fd"
        "bat"
        "eza"
    )

    # Check required binaries
    for bin in "${required_bins[@]}"; do
        if command -v "$bin" &> /dev/null; then
            print_success "Found required: $bin ($(command -v "$bin"))"
        else
            print_error "Missing required binary: $bin"
        fi
    done

    # Check optional binaries
    local missing_optional=()
    for bin in "${optional_bins[@]}"; do
        if ! command -v "$bin" &> /dev/null; then
            missing_optional+=("$bin")
        fi
    done

    if [[ ${#missing_optional[@]} -gt 0 ]]; then
        print_warning "Missing optional binaries: ${missing_optional[*]}"
        print_info "See Brewfile (macOS) or packages.linux.txt (Linux) for installation"
    else
        print_success "All optional binaries found"
    fi
}

# Check script executability
check_script_permissions() {
    print_header "Checking script permissions"
    (( ++CHECKS ))

    local script_dir="$HOME/.local/bin"

    if [[ ! -d "$script_dir" ]]; then
        print_warning "Scripts directory not found: $script_dir"
        print_info "Run 'make stow-scripts' to install scripts"
        return 0
    fi

    local non_executable=()
    local stow_scripts_dir="$DOTFILES_DIR/scripts/.local/bin"

    if [[ ! -d "$stow_scripts_dir" ]]; then
        print_warning "Stow scripts source not found: $stow_scripts_dir"
        return 0
    fi

    for script_src in "$stow_scripts_dir"/*; do
        local script_name
        script_name=$(basename "$script_src")
        local script_path="$script_dir/$script_name"
        if [[ -f "$script_path" ]]; then
            if [[ -x "$script_path" ]]; then
                print_success "Executable: $script_name"
            else
                print_error "Not executable: $script_name"
                non_executable+=("$script_name")
            fi
        else
            print_warning "Not installed: $script_name (run 'make stow-scripts')"
        fi
    done

    if [[ ${#non_executable[@]} -gt 0 ]]; then
        print_info "Run: chmod +x $script_dir/{$(IFS=,; echo "${non_executable[*]}")}"
    fi
}

# Check zsh module chain
check_zsh_modules() {
    print_header "Checking zsh module chain"
    (( ++CHECKS ))

    local rc_dir="$HOME/.config/zsh/rc.d"
    if [[ ! -d "$rc_dir" ]]; then
        print_warning "zsh rc.d directory not found: $rc_dir"
        print_info "Run 'make stow-zsh' to install zsh configuration"
        return 0
    fi

    # Check core modules
    local core_modules=("platform.zsh" "env.zsh" "aliases.zsh" "functions.zsh")
    for mod in "${core_modules[@]}"; do
        if [[ -f "$rc_dir/$mod" ]]; then
            print_success "Found core module: $mod"
        else
            print_error "Missing core module: $mod"
        fi
    done

    # Check platform-specific module for detected OS
    local os_type
    os_type=$(uname -s | tr '[:upper:]' '[:lower:]')
    if [[ "$os_type" == "darwin" ]]; then
        if [[ -f "$rc_dir/env.darwin.zsh" ]]; then
            print_success "Found platform module: env.darwin.zsh"
        else
            print_error "Missing platform module: env.darwin.zsh"
        fi
    elif [[ "$os_type" == "linux" ]]; then
        if [[ -f "$rc_dir/env.linux.zsh" ]]; then
            print_success "Found platform module: env.linux.zsh"
        else
            print_error "Missing platform module: env.linux.zsh"
        fi
    fi

    # Check yalesites tool-dispatch files if yalesites.zsh is present
    if [[ -f "$rc_dir/yalesites.zsh" ]]; then
        for tool_file in "yalesites-lando.zsh" "yalesites-ddev.zsh"; do
            if [[ -f "$rc_dir/$tool_file" ]]; then
                print_success "Found yalesites module: $tool_file"
            else
                print_error "Missing yalesites module: $tool_file (required by yalesites.zsh)"
            fi
        done
    fi
}

# Run shellcheck if available
check_shell_syntax() {
    print_header "Checking shell script syntax"
    (( ++CHECKS ))

    if ! command -v shellcheck &> /dev/null; then
        print_info "shellcheck not installed, skipping syntax check"
        print_info "Install shellcheck for automated shell script validation"
        return 0
    fi

    print_success "shellcheck found, running validation..."

    local script_errors=0

    # Check scripts in .local/bin
    if [[ -d "$HOME/.local/bin" ]]; then
        while IFS= read -r -d '' script; do
            if shellcheck "$script" 2>&1 | grep -q "^In"; then
                print_warning "Issues found in $(basename "$script")"
                (( ++script_errors ))
            fi
        done < <(find "$HOME/.local/bin" -type f -executable -print0 2>/dev/null)
    fi

    # Check zsh config files
    if [[ -d "$HOME/.config/zsh" ]]; then
        while IFS= read -r -d '' script; do
            if [[ $(basename "$script") == *.zsh ]]; then
                if shellcheck -s bash "$script" 2>&1 | grep -q "^In"; then
                    print_warning "Issues found in $(basename "$script")"
                    (( ++script_errors ))
                fi
            fi
        done < <(find "$HOME/.config/zsh" -type f -print0 2>/dev/null)
    fi

    if [[ $script_errors -eq 0 ]]; then
        print_success "No shellcheck issues found"
    else
        print_info "Run shellcheck on individual files for details"
    fi
}

# Check platform-specific dependencies
check_platform_dependencies() {
    print_header "Checking platform-specific dependencies"
    (( ++CHECKS ))

    local os_type
    os_type=$(uname -s | tr '[:upper:]' '[:lower:]')

    case "$os_type" in
        darwin)
            # Check Homebrew
            if command -v brew &> /dev/null; then
                print_success "Homebrew installed: $(brew --version | head -n1)"

                # Check for common formulae
                local homebrew_tools=("tmux" "neovim" "fzf" "ripgrep" "fd")
                local missing_brew=()

                for tool in "${homebrew_tools[@]}"; do
                    if ! brew list "$tool" &> /dev/null; then
                        missing_brew+=("$tool")
                    fi
                done

                if [[ ${#missing_brew[@]} -gt 0 ]]; then
                    print_warning "Missing Homebrew packages: ${missing_brew[*]}"
                    print_info "Run 'brew bundle' to install from Brewfile"
                fi
            else
                print_error "Homebrew not installed"
                print_info "Install from https://brew.sh"
            fi
            ;;

        linux)
            # Check for clipboard utilities
            local clipboard_utils=("xclip" "xsel" "wl-copy")
            local found_clipboard=false

            for util in "${clipboard_utils[@]}"; do
                if command -v "$util" &> /dev/null; then
                    print_success "Clipboard utility found: $util"
                    found_clipboard=true
                    break
                fi
            done

            if [[ $found_clipboard == false ]]; then
                print_warning "No clipboard utility found (xclip, xsel, or wl-clipboard)"
                print_info "Install with: sudo apt install xclip (or xsel/wl-clipboard)"
            fi

            # Check package manager
            if command -v apt &> /dev/null; then
                print_success "Package manager: apt (Debian/Ubuntu)"
                print_info "Install packages with: sudo apt install -y \$(grep -v '^#' packages.linux.txt | tr '\\n' ' ')"
            elif command -v dnf &> /dev/null; then
                print_info "Package manager: dnf (Fedora/RHEL)"
            elif command -v pacman &> /dev/null; then
                print_info "Package manager: pacman (Arch)"
            fi
            ;;
    esac
}

# Print summary
print_summary() {
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "${BLUE}Summary${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "  Checks performed: $CHECKS"

    if [[ $ERRORS -gt 0 ]]; then
        echo -e "  ${RED}Errors: $ERRORS${NC}"
    else
        echo -e "  ${GREEN}Errors: 0${NC}"
    fi

    if [[ $WARNINGS -gt 0 ]]; then
        echo -e "  ${YELLOW}Warnings: $WARNINGS${NC}"
    else
        echo -e "  ${GREEN}Warnings: 0${NC}"
    fi

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    if [[ $ERRORS -gt 0 ]]; then
        echo -e "\n${RED}Dotfiles health check failed${NC}"
        echo "Review errors above and take corrective action"
        return 1
    elif [[ $WARNINGS -gt 0 ]]; then
        echo -e "\n${YELLOW}Dotfiles health check completed with warnings${NC}"
        echo "Consider addressing warnings for optimal setup"
        return 0
    else
        echo -e "\n${GREEN}Dotfiles health check passed!${NC}"
        echo "Your dotfiles installation looks good"
        return 0
    fi
}

# Main execution
main() {
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "${BLUE}Dotfiles Health Check${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    check_dotfiles_dir
    check_platform_detection
    check_symlinks
    check_submodules
    check_binaries
    check_script_permissions
    check_zsh_modules
    check_shell_syntax
    check_platform_dependencies

    print_summary
}

main "$@"
